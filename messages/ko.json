    "privacy": {
        "title": "개인정보 처리방침",
        "last_updated": "마지막 업데이트: {date}",
        "sections": {
            "data_collection": {
                "title": "데이터 수집",
                "content": "이메일 주소와 계정 자격 증명 등 사용자가 직접 제공하는 정보를 수집합니다. 또한 사용자의 승인을 받아 Gmail 계정에서 구독 정보를 분석하기 위한 데이터를 수집합니다."
            },
            "data_usage": {
                "title": "데이터 사용",
                "content": "사용자의 데이터는 구독 관리 서비스 제공 및 개선 목적으로만 사용됩니다. 개인정보를 제3자에게 판매하지 않습니다."
            },
            "data_security": {
                "title": "데이터 보안",
                "content": "데이터를 보호하기 위해 업계 표준 보안 조치를 구현합니다. 모든 통신은 암호화되며 데이터 저장 및 접근 제어에 대한 최상의 관행을 따릅니다."
            },
            "user_rights": {
                "title": "사용자 권리",
                "content": "언제든지 개인정보에 접근하거나 수정, 삭제할 권리가 있습니다. Google 계정 설정을 통해 Gmail 계정 접근 권한을 철회할 수도 있습니다."
            },
            "contact": {
                "title": "문의하기",
                "content": "개인정보 처리방침이나 데이터 처리 방식에 대해 궁금한 점이 있으시면 지원 채널을 통해 문의해 주세요."
            }
        }
    },
    "terms": {
        "title": "이용약관",
        "last_updated": "마지막 업데이트: {date}",
        "sections": {
            "acceptance": {
                "title": "약관 동의",
                "content": "서비스를 사용함으로써 이용약관에 동의하는 것으로 간주됩니다. 약관에 동의하지 않으신다면 서비스를 사용하지 마세요."
            },
            "user_obligations": {
                "title": "사용자 의무",
                "content": "계정 자격 증명의 기밀성을 유지하고 계정에서 발생하는 모든 활동에 대해 책임을 져야 합니다. 승인되지 않은 사용을 즉시 알려야 합니다."
            },
            "service_modification": {
                "title": "서비스 수정",
                "content": "사전 통지 없이 언제든지 서비스를 수정하거나 중단할 권리를 보유합니다. 수정이나 중단에 대해 책임을 지지 않습니다."
            },
            "limitation": {
                "title": "책임 제한",
                "content": "법률이 허용하는 최대한도 내에서 서비스 사용으로 인한 간접적, 부수적, 특수 또는 결과적 손해에 대해 책임을 지지 않습니다."
            },
            "termination": {
                "title": "계약 해지",
                "content": "약관 위반이나 기타 사유로 언제든지 계정을 종료하거나 정지할 권리를 보유합니다."
            },
            "governing_law": {
                "title": "준거법",
                "content": "이 약관은 서비스가 운영되는 관할권의 법률에 따라 해석 및 적용됩니다."
            }
        }
    }
